# İlk denemede hiçbir anahtar gerekmez.
APP_ENV=development
LOG_LEVEL=INFO
DEMO_MODE=true
STORY_PROVIDER=mock
IMAGE_PROVIDER=placeholder
VIDEO_PROVIDER=local_motion
TTS_PROVIDER=local
MUSIC_PROVIDER=generated_demo
SOUND_EFFECT_PROVIDER=generated_demo
OUTPUT_DIR=output
DATABASE_PATH=data/kids_shorts.db
FFMPEG_PATH=
FFPROBE_PATH=
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
AUDIO_SAMPLE_RATE=48000
LOCAL_TTS_VOICE=Microsoft Zira Desktop
SUBTITLE_FONT=Arial
WEB_HOST=127.0.0.1
WEB_PORT=8000
WEB_JOB_WORKERS=1
WEB_POLL_INTERVAL_MS=1500
DEFAULT_LANGUAGE=en
DEFAULT_STORY_CATEGORY=auto
DEFAULT_DURATION_SECONDS=30
DEFAULT_SCENE_COUNT=6
MAX_EPISODE_COST_USD=0
REQUIRE_MANUAL_APPROVAL=true
CONTENT_PROVIDER=fake
VOICE_PROVIDER=fake
MEDIA_PROVIDER=fake
YOUTUBE_UPLOAD_ENABLED=false

# İleride gerçek sağlayıcı bağlarken doldurulabilir:
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
YOUTUBE_CLIENT_SECRETS_FILE=
# Higgsfield CLI uses `higgsfield auth login`; no API key is required.
HIGGSFIELD_MODEL=kling3_0
HIGGSFIELD_OUTPUT_DIR=data/animations
HIGGSFIELD_CLI_COMMAND=higgsfield
# none | higgsfield | runway
VIDEO_PROVIDER=none
RUNWAY_API_KEY=
RUNWAY_MODEL=gen4_turbo
RUNWAY_RATIO=1280:720
RUNWAY_DURATION=5
RUNWAY_POLL_INTERVAL=5
RUNWAY_TIMEOUT=600
RUNWAY_MAX_RETRIES=3
RUNWAY_IMAGE_MODEL=gen4_image
# Up to three comma-separated files: Leo, Scout, and optional environment.
RUNWAY_REFERENCE_IMAGES=
SCENE_MIN_DURATION=5
SCENE_MAX_DURATION=8
SCENE_GENERATION_ATTEMPTS=3
ENABLE_HIGGSFIELD=false
HIGGSFIELD_DRY_RUN=true
HIGGSFIELD_LIP_SYNC=true
